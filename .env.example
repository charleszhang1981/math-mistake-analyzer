# Database URL (Supabase Postgres)
# Example: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?schema=public
DATABASE_URL=""

# Supabase project config
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_STORAGE_BUCKET="wrongbook"

# NextAuth secret (change in production)
# You can generate with: openssl rand -base64 32
NEXTAUTH_SECRET="supersecret-dev-secret"

# Base URL
# For local dev: http://localhost:3000
# NEXTAUTH_URL="http://localhost:3000"

# Trust Host headers (recommended for Docker/PaaS)
AUTH_TRUST_HOST=true

# AI provider: gemini | openai | azure
AI_PROVIDER="gemini"

# OpenAI settings (when AI_PROVIDER="openai")
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
OPENAI_MODEL="gpt-4o"
# Two-stage analyze models (optional, fallback to OPENAI_MODEL)
OPENAI_MODEL_EXTRACT=""
OPENAI_MODEL_REASON=""

# Gemini settings (when AI_PROVIDER="gemini")
GOOGLE_API_KEY=""
GEMINI_BASE_URL=""
GEMINI_MODEL="gemini-2.5-flash"
# Two-stage analyze models (optional, fallback to GEMINI_MODEL)
GEMINI_MODEL_EXTRACT=""
GEMINI_MODEL_REASON=""

# Azure OpenAI settings (when AI_PROVIDER="azure")
AZURE_OPENAI_API_KEY=""
AZURE_OPENAI_ENDPOINT=""
AZURE_OPENAI_DEPLOYMENT=""
AZURE_OPENAI_API_VERSION="2024-02-15-preview"
AZURE_OPENAI_MODEL="gpt-4o"
# Two-stage analyze deployments (optional, fallback to AZURE_OPENAI_DEPLOYMENT)
AZURE_OPENAI_DEPLOYMENT_EXTRACT=""
AZURE_OPENAI_DEPLOYMENT_REASON=""

# Analyze runtime controls
AI_ANALYZE_TIMEOUT_MS="180000"
AI_ANALYZE_STAGE1_MAX_TOKENS="1200"
AI_ANALYZE_STAGE2_MAX_TOKENS="3200"

# Logging
LOG_LEVEL="debug"
DEBUG_DB="false"